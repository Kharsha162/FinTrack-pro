{
  "name": "fin-tech-platform",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm-run-all --parallel dev:backend dev:frontend dev:ml",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:ml": "cd ml-services && npm run dev",
    "install:all": "npm-run-all install:backend install:frontend install:ml",
    "install:backend": "cd backend && npm install",
    "install:frontend": "cd frontend && npm install",
    "install:ml": "cd ml-services && npm install"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}

